# Copiar a env.proxy y rellenar valores (env.proxy está en .gitignore).
# Uso: EnvironmentFile=/home/pc/carrierSync/env.proxy en el servicio systemd.

# Proxy Oxylabs (mismas credenciales que gestion_documental / verification_api)
OXY_USER=
OXY_PASS=
OXY_HOST=unblock.oxylabs.io
OXY_PORT=60000

# 2Captcha - misma API key que gestion_documental (ver scripts_vm/vm-verification-api.service)
API_KEY_2CAPTCHA=

# Opcional: sitekey de reCAPTCHA del SII si no se detecta en la página
# Obtener del HTML del SII (data-sitekey o inspeccionar script de recaptcha)
# SII_RECAPTCHA_SITEKEY=
